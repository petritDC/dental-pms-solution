{
  "guideline_name": "Periodontitis Staging and Grading (2017 World Workshop)",
  "version": "2017",
  "staging": {
    "purpose": "Classify severity and extent based on tissue destruction and factors that affect long term case management complexity.",
    "how_to_stage": {
      "primary_measure": "clinical_attachment_loss_cal",
      "fallback_if_cal_unavailable": "radiographic_bone_loss_rbl",
      "tooth_loss_modifies_stage": true,
      "complexity_can_shift_stage_up": true
    },
    "stages": [
      {
        "stage": "I",
        "severity": {
          "interdental_cal_mm_at_site_of_greatest_loss": {
            "min": 1,
            "max": 2
          },
          "rbl": {
            "root_third": "coronal",
            "percent_of_root_length": {
              "max": 15
            }
          },
          "tooth_loss_due_to_periodontitis": {
            "min": 0,
            "max": 0
          }
        },
        "complexity_local": {
          "max_probing_depth_mm": {
            "max": 4
          },
          "bone_loss_pattern": "mostly_horizontal"
        }
      },
      {
        "stage": "II",
        "severity": {
          "interdental_cal_mm_at_site_of_greatest_loss": {
            "min": 3,
            "max": 4
          },
          "rbl": {
            "root_third": "coronal",
            "percent_of_root_length": {
              "min": 15,
              "max": 33
            }
          },
          "tooth_loss_due_to_periodontitis": {
            "min": 0,
            "max": 0
          }
        },
        "complexity_local": {
          "max_probing_depth_mm": {
            "max": 5
          },
          "bone_loss_pattern": "mostly_horizontal"
        }
      },
      {
        "stage": "III",
        "severity": {
          "interdental_cal_mm_at_site_of_greatest_loss": {
            "min": 5
          },
          "rbl": {
            "extent": "to_middle_third_of_root_and_beyond"
          },
          "tooth_loss_due_to_periodontitis": {
            "min": 1,
            "max": 4
          }
        },
        "complexity_in_addition_to_stage_ii": {
          "probing_depths_mm": {
            "min": 6
          },
          "vertical_bone_loss_mm": {
            "min": 3
          },
          "furcation_involvement_class": [
            "II",
            "III"
          ],
          "ridge_defects": "moderate"
        }
      },
      {
        "stage": "IV",
        "severity": {
          "interdental_cal_mm_at_site_of_greatest_loss": {
            "min": 5
          },
          "rbl": {
            "extent": "to_middle_third_of_root_and_beyond"
          },
          "tooth_loss_due_to_periodontitis": {
            "min": 5
          }
        },
        "complexity_in_addition_to_stage_iii": {
          "need_for_complex_rehabilitation_due_to": [
            "masticatory_dysfunction",
            "secondary_occlusal_trauma_tooth_mobility_degree_2_or_more",
            "severe_ridge_defects",
            "bite_collapse_drifting_flaring",
            "less_than_20_remaining_teeth_or_less_than_10_opposing_pairs"
          ]
        }
      }
    ],
    "extent_and_distribution_descriptor": {
      "apply_to_each_stage": true,
      "options": [
        {
          "type": "localized",
          "definition": "less_than_30_percent_of_teeth_involved"
        },
        {
          "type": "generalized",
          "definition": "not_localized"
        },
        {
          "type": "molar_incisor_pattern",
          "definition": "pattern_descriptor"
        }
      ]
    }
  }
}